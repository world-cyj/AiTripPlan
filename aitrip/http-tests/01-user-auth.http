### ============================================
### 01 — 用户认证接口
### ============================================

@baseUrl = http://localhost:8080
@contentType = application/json

# ------------------------------------------
# 1.1 用户登录（返回 token，复制到 @token）
# ------------------------------------------
### 登录 - 账号1
POST {{baseUrl}}/api/user/login
Content-Type: {{contentType}}

{
  "phone": "13800000001",
  "code": "123456"
}

###

# ------------------------------------------
# 1.2 登录 - 账号2
# ------------------------------------------
### 登录 - 账号2
POST {{baseUrl}}/api/user/login
Content-Type: {{contentType}}

{
  "phone": "13800000002",
  "code": "123456"
}

###

# ------------------------------------------
# 1.3 登录 - 账号3
# ------------------------------------------
### 登录 - 账号3
POST {{baseUrl}}/api/user/login
Content-Type: {{contentType}}

{
  "phone": "13800000003",
  "code": "123456"
}

###

# ------------------------------------------
# 1.4 获取用户信息（需先登录获取 userId）
# ------------------------------------------
### 获取用户信息
GET {{baseUrl}}/api/user/1
Authorization: Bearer {{token}}

###

# ------------------------------------------
# 1.5 获取用户旅行偏好
# ------------------------------------------
### 获取旅行偏好
GET {{baseUrl}}/api/user/1/preference
Authorization: Bearer {{token}}

###

# ------------------------------------------
# 1.6 更新用户旅行偏好
# ------------------------------------------
### 更新旅行偏好
POST {{baseUrl}}/api/user/1/preference
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "city": "西安",
  "typeIds": "1,2",
  "budget": "500元/天"
}

###

# ------------------------------------------
# 1.7 退出登录
# ------------------------------------------
### 退出登录
POST {{baseUrl}}/api/user/logout
Authorization: Bearer {{token}}

###

# ------------------------------------------
# 1.8 错误测试 - 验证码错误
# ------------------------------------------
### 错误验证码登录（期望返回错误）
POST {{baseUrl}}/api/user/login
Content-Type: {{contentType}}

{
  "phone": "13800000001",
  "code": "000000"
}

###

# ------------------------------------------
# 1.9 错误测试 - 手机号格式错误
# ------------------------------------------
### 手机号格式错误
POST {{baseUrl}}/api/user/login
Content-Type: {{contentType}}

{
  "phone": "12345",
  "code": "123456"
}

###
